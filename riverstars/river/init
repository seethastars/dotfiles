# Set keyboard layout
riverctl keyboard-layout it

# Set background and border color
riverctl background-color 0x002b36
riverctl border-color-focused 0x93a1a1
riverctl border-color-unfocused 0x586e75

riverctl focus-follows-cursor always
riverctl hide-cursor timeout 10000 # 10 Seconds in milliseconds
riverctl hide-cursor when-typing enabled
riverctl set-cursor-warp on-focus-change
riverctl set-repeat 50 300

# Touchpad Settings
# Get device name from riverctl list-inputs
riverctl input "pointer-1739-52545-SYNA7DB5:01_06CB:CD41_Touchpad" tap enabled
riverctl input "pointer-1739-52545-SYNA7DB5:01_06CB:CD41_Touchpad" accel-profile flat
riverctl input "pointer-1739-52545-SYNA7DB5:01_06CB:CD41_Touchpad" natural-scroll enabled
riverctl input "pointer-1739-52545-SYNA7DB5:01_06CB:CD41_Touchpad" disable-while-typing enabled
riverctl input "pointer-1739-52545-SYNA7DB5:01_06CB:CD41_Touchpad" disable-while-trackpointing enabled

# Set the default layout generator to be rivertile and start it.
# River will send the process group of the init executable SIGTERM on exit.
riverctl default-layout rivertile
rivertile -view-padding 6 -outer-padding 6 &



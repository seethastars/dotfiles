{
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "дёЂ",
            "2": "дєЊ",
            "3": "дё‰",
            "4": "е››",
            "5": "дє”",
            "6": "е…­",
            "7": "дёѓ",
            "8": "е…«",
            "9": "д№ќ",
            "10": "еЌЃ"
        },
        "on-click": "activate",
        "sort-by-number": true,
        "active-only": false
    },
    "hyprland/window": {
        "format": "<span foreground=\"#ffffff\">п‹ђ </span> {}",
        "max-length": 100
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a, %d. %b %Y - %H:%M}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "<span foreground=\"#ffffff\">{icon}</span> {percent}% ",
        "format-icons": [
            "п†… ",
            "п„‘ "
        ],
        "on-click": "pkill -USR1 gammastep || gammastep",
        "tooltip-format": "Brightness"
    },
    "pulseaudio": {
        "format": "<span foreground=\"#ffffff\">|</span> <span foreground=\"#ffffff\">{icon}</span> {volume}% ",
        "format-bluetooth": "<span foreground=\"#ffffff\">|</span> <span foreground=\"#A7C080\">пЉ”</span> {volume}% ",
        "format-muted": "<span foreground=\"#ffffff\">|</span> <span foreground=\"#ffffff\">пЂ¦</span> ",
        "format-icons": {
            "headphone": "пЂҐ ",
            "default": [
                "пЂ§ ",
                "пЂЁ "
            ]
        },
        "scroll-step": 1,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "ignored-sinks": [
            "Easy Effects Sink"
        ]
    },
    "network": {
        "format": "<span foreground=\"#ffffff\">|</span> {ifname}",
        "format-wifi": "<span foreground=\"#ffffff\">|</span> <span foreground=\"#ffffff\">п‡« </span>",
        "format-ethernet": "<span foreground=\"#3D484D\">|</span> <span foreground=\"#A7C080\">у°Љ— </span> {ipaddr}/{cidr}",
        "format-disconnected": "",
        "tooltip-format": "{ifname} via {gwaddr}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50
    },
    "battery": {
    "bat": "BAT1",
    "interval": 60,
    "states": {
	      "good" : 90,
        "warning": 30,
        "critical": 15
        },
    "format": "| {capacity}% {icon}",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
    "max-length": 25
    },
    "hyprland/language": {
        "format": "<span foreground=\"#A7C080\">у°ЊЊ</span> {short} <span foreground=\"#3D484D\">|</span>"
    },
    "keyboard-state": {
        "capslock": true,
        "format": " <span foreground=\"#A7C080\">у°Є›</span> {icon}",
        "format-icons": {
            "locked": "пЂЈ ",
            "unlocked": "п‚њ "
        }
    },
    "disk": {
        "interval": 30,
        "format": "<span foreground=\"#A7C080\" weight=\"bold\">/</span> {percentage_used}% ",
        "path": "/"
    },
    "cpu": {
        "format": "<span foreground=\"#3D484D\">|</span> <span foreground=\"#A7C080\" weight=\"bold\">CPU</span> {usage}% "
    },
    "memory": {
        "format": "<span foreground=\"#ffffff\">|</span> <span foreground=\"#A7C080\" weight=\"bold\">RAM</span> {}% "
    },
    "custom/wlogout": {
        "format": "вЏ»",
        "on-click": "wlogout",
        "tooltip": false
    }
}
